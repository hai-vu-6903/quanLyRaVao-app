<UserControl x:Class="qlrv.Views.BaoCaoView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="clr-namespace:qlrv.ViewModels"
             xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml">

    <UserControl.DataContext>
        <vm:BaoCaoViewModel/>
    </UserControl.DataContext>

    <Grid Margin="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- ================= TOOLBAR ================= -->
        <ui:Card Grid.Row="0"
                 Padding="12"
                 Margin="0,0,0,12">

            <Grid VerticalAlignment="Center">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                

                <!-- Từ ngày -->
                <StackPanel Grid.Column="0"
                            Orientation="Horizontal"
                            Margin="0,0,12,0"
                            VerticalAlignment="Center">
                    <TextBlock Text="Từ ngày"
                               VerticalAlignment="Center"
                               Margin="0,0,6,0"/>
                    <DatePicker SelectedDate="{Binding TuNgay}"
                                Width="150"/>
                </StackPanel>

                <!-- Đến ngày -->
                <StackPanel Grid.Column="1"
                            Orientation="Horizontal"
                            Margin="0,0,12,0"
                            VerticalAlignment="Center">
                    <TextBlock Text="Đến ngày"
                               VerticalAlignment="Center"
                               Margin="0,0,6,0"/>
                    <DatePicker SelectedDate="{Binding DenNgay}"
                                Width="150"/>
                </StackPanel>

                <!-- Lọc -->
                <ui:Button Grid.Column="2"
                           Icon="Filter20"
                           Content="Lọc"
                           Command="{Binding LocCommand}"
                           Margin="0,0,8,0"/>

                <!-- Xem tất cả -->
                <ui:Button Grid.Column="3"
                           Icon="ArrowSync20"
                           Content="Xem tất cả"
                           Command="{Binding XemTatCaCommand}"/>
                <!-- Xuất Excel -->
                <ui:Button Grid.Column="4"
           Appearance="Success"
           Content="Xuất Excel"
           Command="{Binding XuatExcelCommand}"
           Margin="0,0,12,0">
                    <ui:Button.Icon>
                        <ui:SymbolIcon Symbol="Print24"/>
                    </ui:Button.Icon>
                </ui:Button>
            </Grid>
        </ui:Card>

        <!-- ================= DATA GRID ================= -->
        <ui:Card Grid.Row="1" Padding="6">

            <ui:DataGrid ItemsSource="{Binding LichSu}"
                         AutoGenerateColumns="False"
                         CanUserAddRows="False"
                         RowHeight="40"
                         HeadersVisibility="Column"
                         GridLinesVisibility="None">

                <ui:DataGrid.Columns>
                    <DataGridTextColumn Header="CCCD" Binding="{Binding CCCD}" Width="130"/>
                    <DataGridTextColumn Header="Họ tên" Binding="{Binding HoTen}" Width="160"/>
                    <DataGridTextColumn Header="Quê quán" Binding="{Binding QueQuan}" Width="160"/>
                    <DataGridTextColumn Header="SĐT" Binding="{Binding DienThoai}" Width="120"/>
                    <DataGridTextColumn Header="Loại" Binding="{Binding LoaiDoiTuong}" Width="110"/>
                    <DataGridTextColumn Header="Cấp bậc" Binding="{Binding CapBac}" Width="100"/>
                    <DataGridTextColumn Header="Chức vụ" Binding="{Binding ChucVu}" Width="120"/>
                    <DataGridTextColumn Header="Ra/Vào" Binding="{Binding LoaiRaVao}" Width="80">
                        <DataGridTextColumn.CellStyle>
                            <Style TargetType="DataGridCell">
                                <Setter Property="HorizontalAlignment" Value="Center"/>
                                <Setter Property="VerticalAlignment" Value="Center"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding LoaiRaVao}" Value="Vào">
                                        <Setter Property="Background" Value="#FFDFF5EA"/>
                                        <Setter Property="Foreground" Value="#FF107C41"/>
                                        <Setter Property="FontWeight" Value="Bold"/>
                                    </DataTrigger>
                                    <DataTrigger Binding="{Binding LoaiRaVao}" Value="Ra">
                                        <Setter Property="Background" Value="#FFFDE7E9"/>
                                        <Setter Property="Foreground" Value="#FFC50F1F"/>
                                        <Setter Property="FontWeight" Value="Bold"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </DataGridTextColumn.CellStyle>
                    </DataGridTextColumn>
                    <DataGridTextColumn Header="Thời gian"
                                        Binding="{Binding ThoiGian, StringFormat=dd/MM/yyyy HH:mm:ss}"
                                        Width="170"/>
                    <DataGridTextColumn Header="Người bảo lãnh"
                                        Binding="{Binding NguoiBaoLanh}"
                                        Width="180"/>
                    <DataGridTextColumn Header="Phương tiện" Binding="{Binding PhuongTien}" Width="110"/>
                    <DataGridTextColumn Header="Biển số" Binding="{Binding BienSo}" Width="120"/>
                    <DataGridTextColumn Header="Người trực" Binding="{Binding NguoiTrucGac}" Width="150"/>
                    <DataGridTextColumn Header="Đơn vị trực" Binding="{Binding DonViNguoiTruc}" Width="150"/>
                </ui:DataGrid.Columns>

            </ui:DataGrid>
        </ui:Card>
    </Grid>
</UserControl>