<UserControl x:Class="qlrv.Views.LichSuView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="clr-namespace:qlrv.ViewModels"
             xmlns:converters="clr-namespace:qlrv.Converters"
             xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml">

    <UserControl.Resources>
        <converters:RaButtonConverter x:Key="RaButtonConverter"/>
        <BooleanToVisibilityConverter x:Key="BoolToVis"/>
    </UserControl.Resources>

    <UserControl.DataContext>
        <vm:LichSuViewModel/>
    </UserControl.DataContext>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- ================= THANH TÌM KIẾM ================= -->
        <ui:Card Grid.Row="0" Margin="10" Padding="10">
            <Grid VerticalAlignment="Center">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="320"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <!-- Label -->
                <TextBlock Grid.Column="0"
                   Text="Tìm kiếm"
                   VerticalAlignment="Center"
                   FontWeight="SemiBold"
                   Margin="0,0,8,0"
                   Opacity="0.85"/>

                <!-- Search box -->
                <ui:TextBox Grid.Column="1"
                    Width="300"
                    Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}"
                    PlaceholderText="Tìm theo CCCD, Loại đối tượng"/>

                <!-- Spacer -->
                <Grid Grid.Column="2"/>

                <!-- Export Excel -->
                <ui:Button Grid.Column="3"
                   Content="Xuất Excel"
                   Appearance="Success"
                   Command="{Binding XuatExcelCommand}">
                    <ui:Button.Icon>
                        <ui:SymbolIcon Symbol="Print24"/>
                    </ui:Button.Icon>
                </ui:Button>

            </Grid>
        </ui:Card>


        <!-- ================= DANH SÁCH ================= -->
        <Border Grid.Row="1"
                Visibility="{Binding ListVisibility}"
                Margin="10"
                Background="{DynamicResource CardBackgroundFillColorDefaultBrush}"
                CornerRadius="6">

            <DataGrid ItemsSource="{Binding LichSu}"
                      AutoGenerateColumns="False"
                      CanUserAddRows="False">

                <DataGrid.Columns>
                    <DataGridTextColumn Header="CCCD" Binding="{Binding CCCD}" Width="120"/>
                    <DataGridTextColumn Header="Họ tên" Binding="{Binding HoTen}" Width="150"/>
                    <DataGridTextColumn Header="Đối tượng" Binding="{Binding LoaiDoiTuong}" Width="120"/>
                    
                    <DataGridTextColumn Header="Ra/Vào" Binding="{Binding LoaiRaVao}" Width="80">
                        <DataGridTextColumn.CellStyle>
                            <Style TargetType="DataGridCell">
                                <Setter Property="HorizontalAlignment" Value="Center"/>
                                <Setter Property="VerticalAlignment" Value="Center"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding LoaiRaVao}" Value="Vào">
                                        <Setter Property="Background" Value="#FFDFF5EA"/>
                                        <Setter Property="Foreground" Value="#FF107C41"/>
                                        <Setter Property="FontWeight" Value="Bold"/>
                                    </DataTrigger>
                                    <DataTrigger Binding="{Binding LoaiRaVao}" Value="Ra">
                                        <Setter Property="Background" Value="#FFFDE7E9"/>
                                        <Setter Property="Foreground" Value="#FFC50F1F"/>
                                        <Setter Property="FontWeight" Value="Bold"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </DataGridTextColumn.CellStyle>
                    </DataGridTextColumn>
                    <DataGridTextColumn Header="Thời gian"
                                        Binding="{Binding ThoiGian, StringFormat=dd/MM/yyyy HH:mm}"
                                        Width="140"/>
                    <DataGridTextColumn Header="Phương tiện" Binding="{Binding PhuongTien}" Width="100"/>
                    <DataGridTextColumn Header="Biển số" Binding="{Binding BienSo}" Width="100"/>
                    <DataGridTextColumn Header="Người trực gác"
                    Binding="{Binding NguoiTrucGac}"
                    Width="150"/>

                    <DataGridTextColumn Header="Đơn vị người trực"
                    Binding="{Binding DonViNguoiTruc}"
                    Width="150"/>


                    <!-- THAO TÁC -->
                    <DataGridTemplateColumn Header="" Width="120">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <ui:Button
                                           Command="{Binding DataContext.SuaCommand,
                                           RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                           CommandParameter="{Binding}"
                                           Appearance="Primary">
                                    <ui:Button.Icon>
                                        <ui:SymbolIcon Symbol="Edit24"/>
                                    </ui:Button.Icon>
                                </ui:Button>

                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>
                </DataGrid.Columns>
            </DataGrid>
        </Border>

        <!-- ================= FORM SỬA ================= -->
        <ContentControl Grid.Row="1"
                        Content="{Binding FormView}"
                        Visibility="{Binding FormVisibility}"
                        Margin="10"/>
    </Grid>
</UserControl>