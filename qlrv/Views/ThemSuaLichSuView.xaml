<UserControl x:Class="qlrv.Views.ThemSuaLichSuView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
             >

    <Border  
            CornerRadius="6" Padding="20">
        <StackPanel>
            <TextBlock Text="Chỉnh sửa lịch sử ra/vào" FontSize="16" FontWeight="SemiBold" Margin="0,0,0,10"/>

            <TextBlock Text="Phương tiện"/>
            <ui:TextBox Text="{Binding PhuongTien}" Height="30" Margin="0,2,0,10"/>

            <TextBlock Text="Biển số"/>
            <ui:TextBox Text="{Binding BienSo}" Height="30" Margin="0,2,0,10"/>

            <TextBlock Text="Người trực gác"/>
            <ui:TextBox Text="{Binding NguoiTrucGac}" Height="30" Margin="0,2,0,10"/>

            <TextBlock Text="Đơn vị"/>
            <ui:TextBox Text="{Binding DonViNguoiTruc}" Height="30" Margin="0,2,0,20"/>

            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                <ui:Button Content="Lưu" Command="{Binding LuuCommand}" Appearance="Primary" Margin="0,0,10,0"/>
                <ui:Button Content="Hủy" Command="{Binding HuyCommand}" Appearance="Secondary"/>
            </StackPanel>
        </StackPanel>
    </Border>
</UserControl>
