<UserControl x:Class="qlrv.Views.QuanNhanView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
             xmlns:vm="clr-namespace:qlrv.ViewModels">

    <UserControl.DataContext>
        <vm:QuanNhanViewModel/>
    </UserControl.DataContext>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- ================= THANH TÌM KIẾM ================= -->
        <ui:Card Grid.Row="0"
                Margin="10,10,10,5"
                Padding="10">

            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="320"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <TextBlock Text="Tìm kiếm"
                           VerticalAlignment="Center"
                           FontWeight="SemiBold"
                           Margin="0,0,10,0"/>

                <!-- Search -->
                <Grid Grid.Column="1">
                    <TextBox Height="32"
                             Padding="34,5,10,5"
                             Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}"
                             ToolTip="Tìm theo CCCD, Họ tên, Đơn vị, Cấp bậc, Chức vụ"/>

                    <ui:SymbolIcon Symbol="Search24"
                                   Width="16"
                                   Height="16"
                                   Margin="10,0,0,0"
                                   VerticalAlignment="Center"
                                   HorizontalAlignment="Left"
                                   Foreground="Gray"/>
                </Grid>

                <!-- Clear -->
                <ui:Button Grid.Column="2"
                           Content="Xóa"
                           Appearance="Secondary"
                           Command="{Binding XoaTimKiemCommand}"
                           Margin="10,0,0,0">
                    <ui:Button.Icon>
                        <ui:SymbolIcon Symbol="Dismiss24"/>
                    </ui:Button.Icon>
                </ui:Button>

                <Grid Grid.Column="3"/>

                <!-- Add -->
                <ui:Button Grid.Column="4"
                           Content="Thêm"
                           Appearance="Primary"
                           Command="{Binding ThemCommand}"
                           FontWeight="SemiBold">
                    <ui:Button.Icon>
                        <ui:SymbolIcon Symbol="Add24"/>
                    </ui:Button.Icon>
                </ui:Button>
            </Grid>
        </ui:Card>

        <!-- ================= DANH SÁCH QUÂN NHÂN ================= -->
        <Border Grid.Row="1"
                Margin="10,5,10,5"
                CornerRadius="6"
                Visibility="{Binding ListVisibility}">

            <DataGrid ItemsSource="{Binding DanhSachQuanNhan}"
                      AutoGenerateColumns="False"
                      CanUserAddRows="False"
                      BorderThickness="0"
                      Background="Transparent"
                      RowHeight="38">

                <DataGrid.Columns>

                    <DataGridTextColumn Header="Họ và tên" Binding="{Binding HoTen}" Width="160"/>
                    <DataGridTextColumn Header="Đơn vị" Binding="{Binding DonVi}" Width="140"/>
                    <DataGridTextColumn Header="Cấp bậc" Binding="{Binding CapBac}" Width="110"/>
                    <DataGridTextColumn Header="Chức vụ" Binding="{Binding ChucVu}" Width="130"/>

                    <!-- Trạng thái -->
                    <DataGridTextColumn Header="Trạng thái" Binding="{Binding TrangThai}" Width="90">
                        <DataGridTextColumn.CellStyle>
                            <Style TargetType="DataGridCell">
                                <Setter Property="HorizontalAlignment" Value="Center"/>
                                <Setter Property="VerticalAlignment" Value="Center"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding TrangThai}" Value="Vào">
                                        <Setter Property="Background" Value="#FFDFF5EA"/>
                                        <Setter Property="Foreground" Value="#FF107C41"/>
                                        <Setter Property="FontWeight" Value="Bold"/>
                                    </DataTrigger>
                                    <DataTrigger Binding="{Binding TrangThai}" Value="Ra">
                                        <Setter Property="Background" Value="#FFFDE7E9"/>
                                        <Setter Property="Foreground" Value="#FFC50F1F"/>
                                        <Setter Property="FontWeight" Value="Bold"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </DataGridTextColumn.CellStyle>
                    </DataGridTextColumn>

                    <DataGridTextColumn Header="Thời gian"
                                        Binding="{Binding ThoiGian, StringFormat=dd/MM/yyyy HH:mm}"
                                        Width="150"/>

                    <DataGridTextColumn Header="Phương tiện" Binding="{Binding PhuongTien}" Width="120"/>
                    <DataGridTextColumn Header="Biển số" Binding="{Binding BienSo}" Width="120"/>

                    <!-- Thao tác -->
                    <DataGridTemplateColumn Header="" Width="150">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <StackPanel Orientation="Horizontal"
                                            HorizontalAlignment="Center">

                                    <!-- Sửa -->
                                    <ui:Button Width="42"
                                               Height="38"
                                               Appearance="Secondary"
                                               ToolTip="Sửa"
                                               Command="{Binding DataContext.SuaCommand,
                                                         RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                               CommandParameter="{Binding}">
                                        <ui:Button.Icon>
                                            <ui:SymbolIcon Symbol="Edit24"/>
                                        </ui:Button.Icon>
                                    </ui:Button>

                                    <!-- Xóa -->
                                    <ui:Button Width="42"
                                               Height="38"
                                               Appearance="Danger"
                                               ToolTip="Xóa"
                                               Margin="8,0,0,0"
                                               Command="{Binding DataContext.XoaCommand,
                                                         RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                               CommandParameter="{Binding}">
                                        <ui:Button.Icon>
                                            <ui:SymbolIcon Symbol="Delete24"/>
                                        </ui:Button.Icon>
                                    </ui:Button>

                                </StackPanel>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>

                </DataGrid.Columns>
            </DataGrid>
        </Border>
        <ContentControl Grid.Row="1"
                Content="{Binding FormView}"
                Visibility="{Binding FormVisibility}"
                Margin="10"/>


        <!-- ================= FOOTER ================= -->
        <Border Grid.Row="2"
                Margin="10,5,10,10"
                Padding="10"
                CornerRadius="6">

            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                <ui:Button Appearance="Success"
                           Content="Xuất Excel"
                           Command="{Binding XuatExcelCommand}">
                    <ui:Button.Icon>
                        <ui:SymbolIcon Symbol="Print24"/>
                    </ui:Button.Icon>
                </ui:Button>
            </StackPanel>
        </Border>

    </Grid>
</UserControl>
