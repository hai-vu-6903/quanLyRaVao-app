<Application x:Class="qlrv.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:local="clr-namespace:qlrv"
             xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
             xmlns:converters="clr-namespace:qlrv.Converters"
             StartupUri="MainWindow.xaml">
    <Application.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ui:ThemesDictionary Theme="Light" />
                <ui:ControlsDictionary />
            </ResourceDictionary.MergedDictionaries>
            
            
            <!--<converters:NullToBoolConverter x:Key="NotNullToBoolConverter"/>
            <converters:RaButtonConverter x:Key="RaButtonConverter"/>-->
        </ResourceDictionary>
        
    </Application.Resources>
</Application>
